default_platform(:ios)

# App Store Connect API key (shared across lanes)
ASC_API_KEY_ID = "J7P3F59H9M"
ASC_API_ISSUER_ID = "bba04448-ff86-400c-8a1c-9828ce554f07"
ASC_KEY_PATH = File.expand_path("~/.private_keys/AuthKey_J7P3F59H9M.p8")

# ── iOS ──────────────────────────────────────────────────────────────────

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ASC_API_KEY_ID,
      issuer_id: ASC_API_ISSUER_ID,
      key_filepath: ASC_KEY_PATH,
    )

    # Increment build number to current timestamp (ensures unique build)
    build_number = Time.now.strftime("%Y%m%d%H%M")

    Dir.chdir("..") do
      sh("flutter", "build", "ipa",
         "--release",
         "--build-number=#{build_number}",
         "--export-options-plist=ios/ExportOptions.plist")
    end

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/toolor_app.ipa",
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build iOS release for device install (no upload)"
  lane :build do
    Dir.chdir("..") do
      sh("flutter", "build", "ios", "--release")
    end
  end

  desc "Install on connected device"
  lane :device do
    build
    Dir.chdir("..") do
      sh("bash", "deploy_iphone.sh", "release")
    end
  end
end

# ── Android ──────────────────────────────────────────────────────────────

platform :android do
  desc "Build APK"
  lane :build_apk do
    Dir.chdir("..") do
      sh("flutter", "build", "apk", "--release")
    end
  end

  desc "Build App Bundle and upload to Play Store (internal track)"
  lane :beta do
    build_number = Time.now.strftime("%Y%m%d%H%M")

    Dir.chdir("..") do
      sh("flutter", "build", "appbundle",
         "--release",
         "--build-number=#{build_number}")
    end

    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Build APK and copy to Downloads"
  lane :apk do
    build_apk
    Dir.chdir("..") do
      sh("cp", "build/app/outputs/flutter-apk/app-release.apk",
         File.expand_path("~/Downloads/toolor-release.apk"))
    end
    UI.success("APK copied to ~/Downloads/toolor-release.apk")
  end
end
